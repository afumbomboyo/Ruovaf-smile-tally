
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Simplified rules for Afu & Ruovaf MVP.
     * Allows shared access to fixed partner documents for synchronization.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /partners/{partnerId} {
      // Allow read/write for the Afu & Ruovaf role documents.
      // In a production app, we would use strict UID checks, 
      // but for this specific paired app, we rely on password logic in the UI.
      allow read, write: if isSignedIn();

      match /dailySmileRecords/{recordId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
